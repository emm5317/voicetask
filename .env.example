# === Server ===
APP_PORT=8090

# === Auth ===
# Generate: go run ./cmd/hashpass "your-passphrase"
APP_PASSPHRASE_HASH=$2a$10$REPLACE_ME

# === Database ===
DATABASE_URL=postgres://voicetask:your-db-password@localhost:5432/voicetask?sslmode=disable

# === LLM ===
# Options: claude | openai | groq | ollama
LLM_PROVIDER=claude

# Only the active provider's key is required
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
# OPENAI_API_KEY=sk-REPLACE_ME
# GROQ_API_KEY=gsk_REPLACE_ME
# OLLAMA_URL=http://192.168.x.x:11434

# === Project Tags ===
# Comma-separated. Passed to LLM and used for UI grouping.
PROJECT_TAGS=campbells,personal,sedalia,BofA,gritton,diment,constellation,national life,cinfin
